# ─── Mock Mode ───
# When true, all AI calls use deterministic mock data — no API keys needed.
MOCK_MODE=true

# ─── Frontend / CORS ───
# Comma-separated origins allowed to call the backend.
# Example: FRONTEND_ORIGINS=https://talk.example.com,http://localhost:3000
FRONTEND_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ─── AI Provider Selection ───
LLM_PROVIDER=deepseek
STT_PROVIDER=qwen
TTS_PROVIDER=mock
PRONUNCIATION_PROVIDER=fallback

# ─── DeepSeek (LLM) ───
# Get your key at: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=

# ─── Qwen / DashScope (STT) ───
# Get your key at: https://dashscope.console.aliyun.com/apiKey
DASHSCOPE_API_KEY=

# ─── Azure Speech (Pronunciation) ───
# Optional. If left empty, falls back to local estimator.
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=

# ─── OpenAI (alternative LLM / STT) ───
OPENAI_API_KEY=
